#!/usr/bin/env bash
set -euo pipefail

profile="dev"
role="workstation"
personal="false"
editor="zed"
container="auto"
repo="RobertoVillegas/dotfiles"

usage() {
  cat <<'EOF'
Usage: bootstrap [options]

  --dev                  Install the development profile (default)
  --minimal              Install only the portable core
  --devbox               Configure a headless development host
  --role=workstation|devbox
  --personal             Add personal applications
  --editor=zed|vscode|both|none
  --container=auto|orbstack|docker|none
  --repo=OWNER/REPO      Override the chezmoi repository
  -h, --help             Show this help
EOF
}

while (($#)); do
  case "$1" in
    --dev) profile="dev" ;;
    --minimal) profile="minimal" ;;
    --devbox) profile="dev"; role="devbox"; personal="false"; editor="none" ;;
    --role=*) role="${1#*=}" ;;
    --personal) personal="true" ;;
    --editor=*) editor="${1#*=}" ;;
    --container=*) container="${1#*=}" ;;
    --repo=*) repo="${1#*=}" ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

case "$editor" in zed|vscode|both|none) ;; *) echo "Invalid editor: $editor" >&2; exit 2 ;; esac
case "$role" in workstation|devbox) ;; *) echo "Invalid machine role: $role" >&2; exit 2 ;; esac
case "$container" in auto|orbstack|docker|none) ;; *) echo "Invalid container runtime: $container" >&2; exit 2 ;; esac

if [[ "$role" == "devbox" ]]; then
  profile="dev"
  personal="false"
  editor="none"
fi

export DOTFILES_PROFILE="$profile"
export DOTFILES_ROLE="$role"
export DOTFILES_PERSONAL="$personal"
export DOTFILES_EDITOR="$editor"
export DOTFILES_CONTAINER="$container"

if ! command -v chezmoi >/dev/null 2>&1; then
  bin_dir="$HOME/.local/bin"
  mkdir -p "$bin_dir"
  sh -c "$(curl -fsLS https://get.chezmoi.io)" -- -b "$bin_dir"
  export PATH="$bin_dir:$PATH"
fi

script_dir=""
if [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]]; then
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

if [[ -n "$script_dir" && -d "$script_dir/.git" ]]; then
  chezmoi --source "$script_dir" init --apply
else
  chezmoi init --apply "$repo"
fi

echo
echo "Dotfiles applied: profile=$profile role=$role editor=$editor container=$container personal=$personal"
echo "Restart the shell with: exec zsh -l"
