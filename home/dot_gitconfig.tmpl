{{ if and .gitName .gitEmail -}}
[user]
	name = {{ .gitName }}
	email = {{ .gitEmail }}
{{ end -}}
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
[init]
	defaultBranch = main
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[include]
	path = ~/.gitconfig.local
{{ if eq .profile "dev" -}}
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
{{ end -}}
