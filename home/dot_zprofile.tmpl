{{ if eq .chezmoi.os "darwin" -}}
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

{{ if or (eq .container "auto") (eq .container "orbstack") -}}
[[ -f "$HOME/.orbstack/shell/init.zsh" ]] && source "$HOME/.orbstack/shell/init.zsh"
{{ end -}}
{{ else -}}
[[ -x /home/linuxbrew/.linuxbrew/bin/brew ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

# Homebrew and OrbStack may prepend their own runtimes during login. Restore
# Proto precedence here as well as in .zshenv so non-interactive SSH commands
# and headless agents use the pinned toolchain without requiring .zshrc.
export PATH="$PROTO_HOME/shims:$PROTO_HOME/bin:$PROTO_HOME/tools/node/globals/bin:$HOME/.local/bin:$PATH"
typeset -U path PATH
