#!/bin/sh
set -u

failures=0
warnings=0

pass() { printf 'ok    %s\n' "$1"; }
warn() { printf 'warn  %s\n' "$1"; warnings=$((warnings + 1)); }
fail() { printf 'fail  %s\n' "$1"; failures=$((failures + 1)); }

check_command() {
  if command -v "$1" >/dev/null 2>&1; then
    pass "$1: $(command -v "$1")"
  else
    fail "$1 is not available"
  fi
}

printf 'Devbox doctor\n\n'

for command_name in git gh jq mosh-server node npm proto herdr codex claude opencode tailscale ax agent-browser portless; do
  check_command "$command_name"
done

if command -v tailscale >/dev/null 2>&1 && tailscale status >/dev/null 2>&1; then
  pass "Tailscale is connected"
  tailscale serve status 2>/dev/null || true
else
  warn "Tailscale is not connected or its CLI needs setup"
fi

if command -v docker >/dev/null 2>&1; then
  if docker info >/dev/null 2>&1; then
    pass "Docker daemon is reachable"
  else
    warn "Docker client exists but its daemon is not reachable"
  fi
else
  warn "Docker client is not installed"
fi

for instruction_file in \
  "$HOME/.codex/AGENTS.md" \
  "$HOME/.claude/CLAUDE.md" \
  "$HOME/.config/opencode/AGENTS.md" \
  "$HOME/.agents/skills/devbox-network/SKILL.md" \
  "$HOME/.agents/skills/agent-browser/SKILL.md"; do
  if [ -e "$instruction_file" ]; then
    pass "$instruction_file"
  else
    fail "$instruction_file is missing"
  fi
done

github_identity="$(ssh -G github.com 2>/dev/null | awk '$1 == "identityfile" { print $2; exit }')"
case "$github_identity" in
  '~/'*) github_identity="$HOME/${github_identity#\~/}" ;;
esac
if [ -n "$github_identity" ] && [ -f "$github_identity" ] && [ -f "$github_identity.pub" ]; then
  pass "Dedicated GitHub SSH key exists: $github_identity"
else
  warn "Dedicated GitHub SSH key is not configured or its files are missing"
fi

signing_key="$(git config --global --includes --get user.signingkey 2>/dev/null || true)"
case "$signing_key" in
  '~/'*) signing_key="$HOME/${signing_key#\~/}" ;;
esac
allowed_signers="$(git config --global --includes --get gpg.ssh.allowedSignersFile 2>/dev/null || true)"
case "$allowed_signers" in
  '~/'*) allowed_signers="$HOME/${allowed_signers#\~/}" ;;
esac
if [ "$(git config --global --includes --get commit.gpgsign 2>/dev/null || true)" = "true" ] && \
   [ "$(git config --global --includes --get tag.gpgsign 2>/dev/null || true)" = "true" ] && \
   [ "$(git config --global --includes --get gpg.format 2>/dev/null || true)" = "ssh" ] && \
   [ -f "$signing_key" ] && [ -f "$allowed_signers" ]; then
  pass "Git SSH signing is enabled"
else
  warn "Git SSH signing is not fully configured"
fi

if command -v gh >/dev/null 2>&1 && gh auth status --hostname github.com >/dev/null 2>&1; then
  pass "GitHub CLI OAuth is authenticated"
  gh_hosts="$HOME/.config/gh/hosts.yml"
  if [ -f "$gh_hosts" ]; then
    gh_hosts_mode="$(stat -f '%Lp' "$gh_hosts" 2>/dev/null || stat -c '%a' "$gh_hosts" 2>/dev/null || true)"
    if [ "$gh_hosts_mode" = "600" ]; then
      pass "GitHub CLI headless credential file has mode 600"
    else
      warn "GitHub CLI credential file should have mode 600 (found ${gh_hosts_mode:-unknown})"
    fi
  else
    pass "GitHub CLI uses the system credential store"
  fi
else
  warn "GitHub CLI OAuth is not available in this shell"
fi

printf '\n%d failure(s), %d warning(s)\n' "$failures" "$warnings"
[ "$failures" -eq 0 ]
