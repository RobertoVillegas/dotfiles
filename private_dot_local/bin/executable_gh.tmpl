#!/bin/sh
set -u

if [ -x /opt/homebrew/bin/gh ]; then
  real_gh=/opt/homebrew/bin/gh
elif [ -x /usr/local/bin/gh ]; then
  real_gh=/usr/local/bin/gh
else
  echo "Homebrew gh executable was not found" >&2
  exit 127
fi

if [ -n "${GH_TOKEN:-}" ]; then
  exec "$real_gh" "$@"
fi

token_file="${GH_TOKEN_FILE:-}"
if [ -z "$token_file" ]; then
  repo_slug="${GH_REPO:-}"
  expect_repo=false
  for arg in "$@"; do
    if [ "$expect_repo" = true ]; then
      repo_slug="$arg"
      expect_repo=false
      continue
    fi
    case "$arg" in
      -R|--repo) expect_repo=true ;;
      --repo=*) repo_slug="${arg#--repo=}" ;;
    esac
  done

  if [ -z "$repo_slug" ]; then
    remote_url="$(git remote get-url origin 2>/dev/null || true)"
    case "$remote_url" in
      git@github.com:*) repo_slug="${remote_url#git@github.com:}" ;;
      https://github.com/*) repo_slug="${remote_url#https://github.com/}" ;;
      ssh://git@github.com/*) repo_slug="${remote_url#ssh://git@github.com/}" ;;
    esac
  fi

  owner="$(printf '%s' "${repo_slug%%/*}" | tr '[:upper:]' '[:lower:]')"
  token_name=personal
  owner_map="$HOME/.config/gh-tokens/owners"
  if [ -n "$owner" ] && [ -r "$owner_map" ]; then
    mapped_name="$(git config --file "$owner_map" --get "owner.$owner.token" 2>/dev/null || true)"
    case "$mapped_name" in
      ''|*[!A-Za-z0-9._-]*) ;;
      *) token_name="$mapped_name" ;;
    esac
  fi
  token_file="$HOME/.config/gh-tokens/$token_name"
fi

token=""
if [ -r "$token_file" ]; then
  token="$(tr -d '\r\n' < "$token_file")"
fi
if [ -n "$token" ]; then
  GH_TOKEN="$token" exec "$real_gh" "$@"
fi

exec "$real_gh" "$@"
